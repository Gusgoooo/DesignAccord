    "opacitySubtle": 0.4,
    "fontWeightMedium": 500,
    "fontWeightSemibold": 600,
    "ringWidth": "2px",
    "ringOffset": "2px",
    "paddingXXXS": "2px",
    "textareaMinHeight": "80px",
