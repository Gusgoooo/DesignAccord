{
  "version": 2,
  "description": "Seed→Map 双层 token 系统。seed 层只存核心值，运行 npm run sync:tokens 自动派生 ~175 个 CSS 变量。",
  "seed": {
    "colorPrimary": "#1677ff",
    "colorSuccess": "#52c41a",
    "colorWarning": "#faad14",
    "colorError": "#ff4d4f",
    "colorInfo": "#1677ff",
    "colorLink": "",
    "colorBgBase": "#ffffff",
    "colorTextBase": "#000000",
    "fontSize": 14,
    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans', sans-serif",
    "fontFamilyCode": "'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, Courier, monospace",
    "borderRadius": 6,
    "sizeUnit": 4,
    "sizeStep": 4,
    "controlHeight": 36,
    "lineWidth": 1,
    "motionUnit": 0.1,
    "motionBase": 0,
    "zIndexBase": 0,
    "zIndexPopupBase": 1000
